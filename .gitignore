# .gitignore

# ── Compiled binaries ──────────────────────────────────────────────────────
/flow
/flow.exe
/bin/
/dist/

# Test binaries and coverage
*.test
*.out
coverage.txt
coverage.html
*.coverprofile

# ── GoReleaser output ──────────────────────────────────────────────────────
/dist/

# ── Environment / secrets ─────────────────────────────────────────────────
.env
.env.local
.envrc

# ── OS cruft ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.vim/

# ── Go workspace ──────────────────────────────────────────────────────────
go.work
go.work.sum
